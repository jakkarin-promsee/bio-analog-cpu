{"nodes": [{"id": "draft6_0_research_north_star_th_13_compression", "label": "North-star 13 \u2014 Learning IS Compression", "file_type": "document", "source_file": "draft6.0\\research\\north-star\\th\\13-compression.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Thesis file: 'learning is compression' (MDL) means fitting-on-chip and learning-well are ONE objective; the spare-capacity intuition has three literature names."}, {"id": "draft6_0_research_north_star_th_13_compression_mdl", "label": "MDL / learning-is-compression", "file_type": "rationale", "source_file": "draft6.0\\research\\north-star\\th\\13-compression.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Minimum Description Length (Rissanen 1978; Hinton & van Camp 1993): a model that generalizes is one that compresses; regularization = implementing MDL. For the chip: need a learning rule that compresses as it learns, not a separate compressor."}, {"id": "draft6_0_research_north_star_th_13_compression_double_descent", "label": "Double descent", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\13-compression.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Belkin et al. 2019: over-parameterization is safe/beneficial ('noise cancels itself'); analog smoothing biases toward minimum-norm \u2014 don't fear extra Scap."}, {"id": "draft6_0_research_north_star_th_13_compression_intrinsic_dimension", "label": "Intrinsic dimension", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\13-compression.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Li et al. ICLR 2018: real task dimension << parameter count; the ultimate resident-weight license \u2014 store low-dim thing in high-dim substrate."}, {"id": "draft6_0_research_north_star_th_13_compression_lottery_ticket", "label": "Lottery Ticket Hypothesis", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\13-compression.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Frankle & Carbin 2019: 80-90% of capacity is learning-overhead, not run-overhead; maps to wake (over-provisioned) / sleep (consolidate to winning ticket)."}, {"id": "draft6_0_research_north_star_th_13_compression_superposition", "label": "Superposition (Toy Models)", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\13-compression.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Anthropic Elhage et al. 2022: under sparsity a net packs k>n features as near-orthogonal directions; the author's shared-spare-capacity intuition made rigorous \u2014 sparsity is its precondition."}, {"id": "draft6_0_research_north_star_th_13_compression_spare_capacity", "label": "Spare-capacity hypothesis (author)", "file_type": "rationale", "source_file": "draft6.0\\research\\north-star\\th\\13-compression.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each neuron has an under-used task-cap and shareable slack \u2014 confirmed three ways: slack real (lottery ticket), task small (intrinsic dimension), slack shared (superposition)."}], "edges": [{"source": "draft6_0_research_north_star_th_13_compression", "target": "draft6_0_research_north_star_th_13_compression_mdl", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\13-compression.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_13_compression", "target": "draft6_0_research_north_star_th_13_compression_double_descent"