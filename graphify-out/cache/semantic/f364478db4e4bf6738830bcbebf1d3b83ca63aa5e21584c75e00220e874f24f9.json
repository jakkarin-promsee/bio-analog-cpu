{"nodes": [{"id": "draft_journey_draft3_2_doc", "label": "Draft 3.2 (honest framing pivot)", "file_type": "document", "source_file": "draft-journey\\draft3.2.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Drops the false 'implements chain rule' claim; reframes as attribution-based learning in the three-factor/LRP family."}, {"id": "draft_journey_draft3_2_attribution_based_learning", "label": "Attribution-based learning (three-factor / LRP family)", "file_type": "rationale", "source_file": "draft-journey\\draft3.2.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The honest reframe: this is NOT the chain rule (dz/dW=a, not a*W). It is credit assignment by contribution (|a*W|), input-centric not sensitivity-based; the substrate measures it for free. The central bet that later broke on the missing sign."}, {"id": "draft_journey_draft3_2_honest_framing_pivot", "label": "Honest framing pivot", "file_type": "rationale", "source_file": "draft-journey\\draft3.2.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Dropping the impressive-but-false 'approximate backprop' claim for the true-and-falsifiable 'attribution-based learning'. The moment the project became publishable in principle; honest framing > impressive framing."}], "edges": [{"source": "draft_journey_draft3_2_doc", "target": "draft_journey_draft3_1_doc", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft3.2.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft3_2_doc", "target": "draft_journey_draft3_2_attribution_based_learning", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft3.2.md", "source_location": null, "weight": 1.0}, {"source": "draft_jou