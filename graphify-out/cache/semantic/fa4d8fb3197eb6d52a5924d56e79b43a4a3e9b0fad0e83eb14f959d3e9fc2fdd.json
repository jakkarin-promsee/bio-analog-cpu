{"nodes": [{"id": "draft6_0_research_papers_phase9_north_star_bridges", "label": "North-star bridges (story file)", "file_type": "document", "source_file": "draft6.0\\research\\papers\\phase9\\north-star-bridges.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": null}, {"id": "draft6_0_research_papers_phase9_north_star_bridges_pondernet", "label": "PonderNet / ACT (learned halting)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\north-star-bridges.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Learned halting = think until the feeling crosses theta; the threshold gate is PonderNet's static, one-shot ancestor. Build the gate well now and it is the seed of the recurrent brain."}, {"id": "draft6_0_research_papers_phase9_north_star_bridges_tent", "label": "TENT (test-time entropy minimization)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\north-star-bridges.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Adapts a model at test time by minimizing entropy (make myself more confident) \u2014 but entropy is a MAGNITUDE, the density-not-class trap one level up; cautioned, conflicts with the spine."}, {"id": "draft6_0_research_papers_phase9_north_star_bridges_cosine_margin", "label": "Cosine margin (direction-grounded feeling)", "file_type": "rationale", "source_file": "draft6.0\\research\\papers\\phase9\\north-star-bridges.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The spine-clean candidate for the north-star 'feeling': a cosine margin (angle to nearest vs runner-up class) is a DIRECTION; softmax confidence/entropy and Mahalanobis distance are magnitudes to avoid. Build the gate on direction so the recurrent brain can reuse it."}, {"id": "draft6_0_research_papers_phase9_north_star_bridges_calibration_shift", "label": "Calibration under shift (the missing third leg)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\north-star-bridges.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Any halting/exit signal assumes calibrated outputs, and frozen-backbone heads are systematically mis-calibrated under shift; even a direction-grounded feeling needs re-calibration at sleep."}], "edges": [{"source": "draft6_0_research_papers_phase9_north_star_bridges", "target": "draft6_0_research_papers_phase8_the_economy_gate", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\papers\\phase9\\north-star-bridges.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_papers_phase9_north_star_bridges_pondernet", "target": "draft6_0_src_phase9_final_architecture_awake_gate", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\papers\\phase9\\north-star-bridges.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_papers_phase9_north_star_bridges_tent", "target": "draft6_0_src_phase9_final_architecture_the_spine", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\papers\\phase9\\north-star-bridges.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_papers_phase9_north_star_bridges_cosine_margin", "target": "draft6_0_src_phase9_final_architecture_the_spine", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\papers\\phase9\\north-star-bridges.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_papers_phase9_north_star_bridges_pondernet", "target"