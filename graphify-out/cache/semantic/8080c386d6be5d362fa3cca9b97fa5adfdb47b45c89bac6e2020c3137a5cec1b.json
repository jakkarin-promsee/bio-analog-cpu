{"nodes": [{"id": "draft6_0_research_papers_phase10_readme", "label": "Phase 10 papers README (fair fight + gauntlet + Pareto)", "file_type": "document", "source_file": "draft6.0\\research\\papers\\phase10\\README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Literature Phase 10 stands on: the fair same-budget continual baseline, CL metric provenance, three-scenario framing, online/anytime eval convention, accuracy-vs-energy Pareto \u2014 sharpens the rough plan into a stronger, honest bake-off."}, {"id": "draft6_0_research_papers_phase10_budgeted_cl", "label": "Computationally Budgeted Continual Learning (Prabhu 2023)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase10\\README.md", "source_location": null, "source_url": "https://arxiv.org/abs/2303.11165", "captured_at": null, "author": null, "contributor": null, "rationale": "Budget must be FLOPs-per-sample + total bytes, matched across methods; under that budget a naive well-tuned ER beats fancy CL methods \u2014 the opponent is a strong baseline, not a strawman."}, {"id": "draft6_0_research_papers_phase10_realtime_eval", "label": "Real-Time Evaluation in Online CL (Ghunaim 2023)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase10\\README.md", "source_location": null, "source_url": "https://arxiv.org/abs/2302.01047", "captured_at": null, "author": null, "contributor": null, "rationale": "In a real-time stream that doesn't wait for training, ER beats SOTA because expensive per-step training falls behind \u2014 the motivating frame for why a cheap forward-only learner wins the stream; throughput/steps-behind adopted as a measured read in the gauntlet."}, {"id": "draft6_0_research_papers_phase10_aaa_metric", "label": "Average Anytime Accuracy (AAA, origin OSAKA)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase10\\README.md", "source_location": null, "source_url": "