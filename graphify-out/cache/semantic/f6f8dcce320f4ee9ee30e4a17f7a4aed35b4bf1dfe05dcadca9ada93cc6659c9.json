{"nodes": [{"id": "agent_optimize_guide_agent_optimize_guide", "label": "AGENT-OPTIMIZE-GUIDE.md", "file_type": "document", "source_file": "AGENT-OPTIMIZE-GUIDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "agent_optimize_guide_light_top_deep_on_demand", "label": "Light Top, Deep on Demand Principle", "file_type": "rationale", "source_file": "AGENT-OPTIMIZE-GUIDE.md", "source_location": "\u00a71", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Context is layered so an agent loads a little and descends only into the branch its task needs; never let detail float up into a stable layer. Justified not only by token cost but because an LLM's accuracy drops as irrelevant context grows (context rot / finite attention budget), so a leaner context is a more correct agent, not just a cheaper one."}, {"id": "agent_optimize_guide_context_rot", "label": "Context Rot", "file_type": "concept", "source_file": "AGENT-OPTIMIZE-GUIDE.md", "source_location": "\u00a71", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The phenomenon that an LLM's accuracy degrades as irrelevant context accumulates in its finite attention budget - the measured justification (2026-06) for this repo's layered CLAUDE.md system: over-reading pulled ~1,000+ lines for a one-line fact before the redesign."}, {"id": "external_claude_code_large_codebases_guide", "label": "Claude Code - Large-Codebase Guide", "file_type": "document", "source_file": "AGENT-OPTIMIZE-GUIDE.md", "source_location": null, "source_url": "https://code.claude.com/docs/en/large-codebases", "captured_at": null, "author": null, "contributor": null}, {"id": "external_anthropic_context_engineering", "label": "Anthropic - Effective Context Engineering for AI Agents", "file_type": "document", "source_file": "AGENT-OPTIMIZE-GUIDE.md", "source_location": null, "source_url": "https://www.anthropic.com/engineering/effective-context-engineering-for-ai-agents", "captured_at": null, "author": null, "contributor": null}, {"id": "external_agents_md_standard", "label": "AGENTS.md - the cross-tool standard", "file_type": "document", "source_file": "AGENT-OPTIMIZE-GUIDE.md", "source_location": null, "source_url": "https://agents.md/", "captured_at": null, "author": null, "contributor": null}, {"id": "external_cursor_rules_docs", "label": "Cursor rules docs", "file_type": "document", "source_file": "AGENT-OPTIMIZE-GUIDE.md", "source_location": null, "source_url": "https://cursor.com/docs/rules", "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "agent_optimize_guide_agent_optimize_guide", "target": "claude_skills_explore_skill_three_layer_context_hierarchy", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AGENT-OPTIMIZE-GUIDE.md", "source_location": "\u00a72", "weight": 1.0}, {"source": "agent_optimize_guide_light_top_deep_on_demand", "target": "claude_skills_explore_skill_three_layer_context_hierarchy", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AGENT-OPTIMIZE-GUIDE.md", "source_location": "\u00a71", "weight": 1.0}, {"source": "agent_optimize_guide_agent_optimize_guide", "target": "agent_optimize_guide_context_rot", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AGENT-OPTIMIZE-GUIDE.md", "source_location": "\u00a71", "weight": 1.0}, {"source": "agent_optimize_guide_context_rot", "target": "external_anthropic_context_engineering", "relation": "cites", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AGENT-OPTIMIZE-GUIDE.md", "source_location": "\u00a79", "weight": 1.0}, {"source": "agent_optimize_guide_agent_optimize_guide", "target": "external_claude_code_large_codebases_guide", "relation": "cites", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AGE