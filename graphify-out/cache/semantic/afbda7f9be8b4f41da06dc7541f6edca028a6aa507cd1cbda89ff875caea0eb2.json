{"nodes": [{"id": "draft6_0_research_north_star_th_14_compression_methods", "label": "North-star 14 \u2014 How Compression Is Actually Done", "file_type": "document", "source_file": "draft6.0\\research\\north-star\\th\\14-compression-methods.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Concrete methods + mapping of the author's two cross-layer mechanisms; compression = circuit topology + learning discipline, life-or-death for resident-weight."}, {"id": "draft6_0_research_north_star_th_14_compression_methods_deep_compression", "label": "Deep Compression / Pruning", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\14-compression-methods.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Han/Mao/Dally 2016 (LeCun OBD 1989): prune+quantize+Huffman = 35-49x; analog pruning = let low-magnitude Scaps leak to zero in sleep."}, {"id": "draft6_0_research_north_star_th_14_compression_methods_knowledge_distillation", "label": "Knowledge Distillation", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\14-compression-methods.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hinton/Vinyals/Dean 2015: dark knowledge in soft labels; SCFF front = teacher, GD readout = student, sleep = distillation session."}, {"id": "draft6_0_research_north_star_th_14_compression_methods_lora", "label": "Low-rank factorization / LoRA", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\14-compression-methods.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hu et al. 2021: structural compression W\u2248A\u00b7B; a big crossbar becomes two small ones in series \u2014 build structured, not dense."}, {"id": "draft6_0_research_north_star_th_14_compression_methods_hashednets", "label": "Weight sharing / HashedNets", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\14-compression-methods.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Chen et al. 2015: many connections, one stored value; analog = many Scaps referencing one refill-SRAM voltage. Rich connectivity, cheap storage."}, {"id": "draft6_0_research_north_star_th_14_compression_methods_densenet", "label": "DenseNet feature reuse (= mechanism A)", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\14-compression-methods.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Huang et al. CVPR 2017: the author's mechanism A (a layer takes input from 2 layers back to widen range) IS local dense connectivity; reuse compresses by not recomputing. Author also foresaw its divergence failure mode."}, {"id": "draft6_0_research_north_star_th_14_compression_methods_supervised_anchor", "label": "Supervised anchor (= mechanism B)", "file_type": "rationale", "source_file": "draft6.0\\research\\north-star\\th\\14-compression-methods.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The author's 'clipping trigger + inject label' = checkpoint normalization + label grounding, same role as the draft-6.0 GD checkpoint between SCFF blocks; DenseNet needs pre-conv BN for the same reason."}], "edges": [{"source": "draft6_0_research_north_star_th_14_compression_methods", "target": "draft6_0_research_north_star_th_14_compression_methods_deep_compression", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\14-compression-methods.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_14_compression_metho