{"nodes": [{"id": "draft6_0_research_north_star_th_5_continual", "label": "North-star 5 \u2014 Continual / Lifelong Learning", "file_type": "document", "source_file": "draft6.0\\research\\north-star\\th\\5-continual.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The commitment to never stop learning in deployment; enemy = catastrophic forgetting; defenses on two fronts (weight-side + memory-side), the deepest being CLS sleep already half-built."}, {"id": "draft6_0_research_north_star_th_5_continual_stability_plasticity", "label": "Stability-plasticity dilemma", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\5-continual.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "McCloskey & Cohen 1989: plastic=forgets fast, stable=can't learn; the chip's main risk once it learns during deploy; SCFF slow weights + LUT/sleep are the structural answers."}, {"id": "draft6_0_research_north_star_th_5_continual_ewc", "label": "Elastic Weight Consolidation", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\5-continual.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Kirkpatrick et al. 2017: Fisher-weighted quadratic penalty slows important weights; analog = variable-resistance Scap RC constant scaled by F; a good first patch but must pair with replay long-term."}, {"id": "draft6_0_research_north_star_th_5_continual_si_mas", "label": "Synaptic Intelligence / Memory-Aware Synapses", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\5-continual.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Zenke 2017 / Aljundi 2018: online, task-boundary-free importance (MAS is unsupervised); best fit for an always-on chip \u2014 a cheap accumulator/perturbation test per Scap."}, {"id": "draft6_0_research_north_star_th_5_continual_generative_replay", "label": "Deep Generative Replay", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\5-continual.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Shin et al. 2017: a generator dreams pseudo-samples of old tasks (=sleep replay); the upgrade path for the LUT+sleep \u2014 world-model M generates replay instead of a fixed buffer."}, {"id": "draft6_0_research_north_star_th_5_continual_progressive_networks", "label": "Progressive Neural Networks", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\5-continual.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Rusu et al. 2016: grow columns, freeze old, lateral reuse = zero forgetting; for fixed Scap, borrow only 'protect committed, learn in the free' + reserve an expansion budget."}], "edges": [{"source": "draft6_0_research_north_star_th_5_continual", "target": "draft6_0_research_north_star_th_5_continual_stability_plasticity", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\5-continual.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_5_continual", "target": "draft6_0_research_north_star_th_5_continual_ewc", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\5-continual.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_5_continual", "target": "draft6_0_research_north_star_th_5_continual_si_mas", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\5-continual.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_5_continual", "target": "draft6_0_research_north_star_th_5_continual_generative_replay", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\5-continual.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_5_continual", "target": "draft6_0_research_north_star_th_5_continual_progressive_networks", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\5-continual.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_5_continual_ewc", "target": "draft6_0_research_north_star_th_5_continual_si_mas", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\5-continual.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_5_continual_generative_replay", "target": "draft6_0_research_north_star_th_4_signal_world_models", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\5-continual.md", "source_location": null, "weight": 1.0}], "hyperedges": []}