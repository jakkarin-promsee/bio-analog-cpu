{"nodes": [{"id": "draft6_0_research_north_star_th_9_hierarchy", "label": "North-star 9 \u2014 Hierarchy: How Others Stack Levels", "file_type": "document", "source_file": "draft6.0\\research\\north-star\\th\\9-hierarchy.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hierarchy is not a static stack \u2014 it's a two-way LOOP (predict-down/error-up) with dynamic input-dependent structure; what draft-5's hierarchy was missing (top-down loop, dynamic agreement, time)."}, {"id": "draft6_0_research_north_star_th_9_hierarchy_hpc", "label": "Hierarchical Predictive Coding", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\9-hierarchy.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Rao & Ballard 1999 / Friston: prediction flows down, error flows up, all levels settle; the missing top-down loop; error = native analog subtraction, sparse."}, {"id": "draft6_0_research_north_star_th_9_hierarchy_glom", "label": "GLOM", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\9-hierarchy.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hinton 2021: dynamic part-whole via 'islands of agreement' (bottom-up+top-down+lateral); parse tree emerges per input; lateral agreement = free analog resistive coupling."}, {"id": "draft6_0_research_north_star_th_9_hierarchy_htm", "label": "Hierarchical Temporal Memory (HTM)", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\9-hierarchy.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hawkins/Numenta: SP+TM repeated at every level on sparse code, Hebbian/online/local; SP~SCFF, TM=temporal prediction loop Phase 2 needs; distal dendrites = eligibility traces."}, {"id": "draft6_0_research_north_star_th_9_hierarchy_slot_attention", "label": "Slot Attention / object-centric", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\9-hierarchy.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Locatello et al. 2020: slots compete (normalize-across-slots) to claim features -> entities without labels; slot = object in working memory; competition = analog WTA/lateral inhibition."}, {"id": "draft6_0_research_north_star_th_9_hierarchy_moe", "label": "Mixture-of-Experts routing", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\9-hierarchy.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Shazeer 2017 / Switch Transformer: sparse top-k routing, experts self-specialize; = RIMs at hierarchy scale; wide-and-mostly-asleep beats deep-and-all-active with a good router."}, {"id": "draft6_0_research_north_star_th_9_hierarchy_greedy_layerwise", "label": "Greedy layer-wise growth", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\9-hierarchy.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deep Belief Nets 2006 / Forward-Forward: train level, freeze, train next; the HOW of building the hierarchy \u2014 SCFF stacking + boosting already do it; grow Phase-2 one level at a time."}], "edges": [{"source": "draft6_0_research_north_star_th_9_hierarchy", "target": "draft6_0_research_north_star_th_9_hierarchy_hpc", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\9-hierarchy.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_9_hierarchy", "target": "draft6_0_research_north_star_th_9_hierarchy_glom", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, 