{"nodes": [{"id": "draft6_0_research_papers_phase8_deep_research_delta", "label": "Phase 8 deep-research delta", "file_type": "document", "source_file": "draft6.0\\research\\papers\\phase8\\deep-research-delta.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": null}, {"id": "draft6_0_research_papers_phase8_deep_research_delta_cddm_benchmark", "label": "CDDM benchmark & drift-type taxonomy", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase8\\deep-research-delta.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "2024 race of 14 detectors across four drift types; finding: ADWIN excels at class-prior drift but almost systematically flags virtual drift as real, while error detectors are precise but lag."}, {"id": "draft6_0_research_papers_phase8_deep_research_delta_studd", "label": "STUDD (student-teacher unsupervised drift)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase8\\deep-research-delta.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Label-free detector: monitor a student mimicking a teacher. More conservative than ADWIN-on-features (fewer false alarms, slower) \u2014 the false-fire-aware arm, since for us false fires are the expensive failure."}, {"id": "draft6_0_research_papers_phase8_deep_research_delta_driftlens", "label": "DriftLens (embedding-distance drift)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase8\\deep-research-delta.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Real-time distribution-distance detector on model embeddings vs a fixed reference \u2014 purpose-built 'fire when the SCFF taps move'; carried as the label-free reference."}, {"id": "draft6_0_research_papers_phase8_deep_research_delta_adwin_u", "label": "ADWIN-U (unsupervised input moments)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase8\\deep-research-delta.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A real published method (KAIS 2025) running ADWIN on input higher-order moments; most sensitive to the covariate/nuisance shift we want to ignore, so carried as the predicted-to-false-fire null, not our candidate."}, {"id": "draft6_0_research_papers_phase8_deep_research_delta_eval_vocab", "label": "Drift eval vocabulary (MTD/MTFA/FAR/MDR)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase8\\deep-research-delta.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Standard false-fire metrics; the fundamental trade-off is optimizing MTFA necessarily worsens MTD/MDR \u2014 the gate bake-off is choosing where on this Pareto the 80/20 lives."}, {"id": "draft6_0_research_papers_phase8_deep_research_delta_coadapting_backbone", "label": "Co-adapting backbone / representation drift", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase8\\deep-research-delta.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Named literature on a live drifting SCFF: (a) exemplar replay + re-forward (= our sleep/LUT) vs (b) exemplar-free drift-compensation (SDC/LDC). Our sleep is the valid principled answer; (b) is the road-not-taken."}, {"id": "draft6_0_research_papers_phase8_deep_research_delta_cost_meter", "label": "ADC-centred behavioral cost meter (NeuroSim family)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase8\\deep-research-delta.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Behavioral macro-model (DNN+NeuroSim/ISAAC/PUMA/AIHWKit level), relative-pJ not SPICE; ADC energy dominates (e_ADC >> e_MAC), writes rare-but-expensive; reduces to the P7 op-count proxy under unit energies."}, {"id": "draft6_0_research_papers_phase8_deep_research_delta_real_virtual_drift", "label": "Real vs virtual/nuisance drift", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase8\\deep-research-delta.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Real drift moves P(y|x) (should fire); virtual/nuisance drift moves P(x) only (firing = false fire). The nuisance-covariate injector is the load-bearing new test-stream piece."}], "edges": [{"source": "draft6_0_research_papers_phase8_deep_research_delta", "target": "draft6_0_research_papers_phase8_the_economy_gate", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\papers\\phase8\\deep-research-delta.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_papers_phase8_deep_research_delta", "target": "draft6_0_research_papers_phase9_north_star_bridges", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\papers\\phase8\\deep-research-delta.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_papers_phase8_deep_research_delta", "target": "draft6_0_research_papers_phase9_slow_coordination", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\papers\\phase8\\deep-research-delta.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_papers_phase8_deep_research_delta_cddm_benchmark", "target": "draft6_0_research_papers_phase8_the_economy_gate_adwin", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\papers\\phase8\\deep-research-delta.md", "source_loc