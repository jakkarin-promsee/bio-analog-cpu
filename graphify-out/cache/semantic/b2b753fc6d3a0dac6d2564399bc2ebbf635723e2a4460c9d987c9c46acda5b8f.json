{"nodes": [{"id": "draft6_0_research_papers_phase8_the_economy_gate", "label": "Phase 8: the economy gate (paper story)", "file_type": "document", "source_file": "draft6.0\\research\\papers\\phase8\\the-economy-gate.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": null}, {"id": "draft6_0_research_papers_phase8_the_economy_gate_learning_gate", "label": "Threshold learning-gate (the 80/20 economy)", "file_type": "rationale", "source_file": "draft6.0\\research\\papers\\phase8\\the-economy-gate.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Run cheap local SCFF most steps; spend an expensive GD update only when the cheap path stalls (L<\u03b8 SCFF-only; L\u2265\u03b8 SCFF+GD). Gate on loss-slope/plateau, not absolute loss. Framed as choose-and-tune, since drift-detection already solves 'when has the cheap model gone stale'."}, {"id": "draft6_0_research_papers_phase8_the_economy_gate_ddm", "label": "DDM (Drift Detection Method)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase8\\the-economy-gate.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Monitors online error rate + std with two thresholds (warning, drift); maps line-for-line onto the two-threshold gate plus sleep replay. Consumes a labeled error rate."}, {"id": "draft6_0_research_papers_phase8_the_economy_gate_adwin", "label": "ADWIN (Adaptive Windowing)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase8\\the-economy-gate.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Two-window mean-difference drift test = the fast-EMA-vs-slow-EMA plateau detector made rigorous; moves the magic number to the confidence parameter delta rather than removing it."}, {"id": "draft6_0_research_papers_phase8_the_economy_gate_skip_rnn", "label": "Skip-RNN (learned budget gate)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase8\\the-economy-gate.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Learns a binary update/skip decision plus a budget loss (cost per update) that writes the 80/20 target directly into the objective."}, {"id": "draft6_0_research_papers_phase8_the_economy_gate_dni", "label": "Synthetic Gradients / DNI (the 'don't')", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase8\\the-economy-gate.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Predicts the coming gradient so a layer updates without waiting; filed as a DON'T because a predicted supervised gradient injected upstream of SCFF is the fast-supervised poison the kickoff frame forbids, and it degrades on deeper nets."}], "edges": [{"source": "draft6_0_research_papers_phase8_the_economy_gate", "target": "draft6_0_research_survey_sgr_detail_sgr", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\papers\\phase8\\the-economy-gate.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_papers_phase8_the_economy_gate", "target": "draft6_0_research_papers_phase9_maintenance_and_replay", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\papers\\phase8\\the-economy-gate.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_papers_phase8_the_economy_gate", "target": "draft6_0_research_papers_phase8_the_economy_gate_learning_gate", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\papers\\phase8\\the-economy-gate.md", "source_location": null, "weight": 1.0}, {"sourc