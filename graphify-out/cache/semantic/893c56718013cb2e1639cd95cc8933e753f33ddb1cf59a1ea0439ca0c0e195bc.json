{"nodes": [{"id": "draft6_0_research_papers_phase9_maintenance_and_replay", "label": "Maintenance, sleep, replay (story file)", "file_type": "document", "source_file": "draft6.0\\research\\papers\\phase9\\maintenance-and-replay.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": null}, {"id": "draft6_0_research_papers_phase9_maintenance_and_replay_experience_replay", "label": "Experience replay (sleep)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\maintenance-and-replay.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Keep old data and mix it back in; inspired by memory consolidation during sleep. Our sleep+LUT, named. The most reliable continual method; cheap for us because only the readout is replayed."}, {"id": "draft6_0_research_papers_phase9_maintenance_and_replay_ewc", "label": "EWC / SI / MAS (regularization family)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\maintenance-and-replay.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Estimate which weights matter and penalize moving them (Fisher / online importance). The cheaper-memory alternative to replay; SI's per-weight running statistic = the same register kind the Scap holds for momentum/BCM."}, {"id": "draft6_0_research_papers_phase9_maintenance_and_replay_agem", "label": "A-GEM (efficient same-budget replay baseline)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\maintenance-and-replay.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Projects the new gradient so it doesn't increase loss on the replay buffer; the fair same-budget BP+replay baseline (race_bp + buffer) the architecture owes, since Phase 4's win was vs naive online-BP."}, {"id": "draft6_0_research_papers_phase9_maintenance_and_replay_remind", "label": "REMIND (frozen-backbone feature replay)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\maintenance-and-replay.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Frozen backbone + compressed feature replay into the head; the closest published cousin to our sleep/LUT \u2014 but it freezes the backbone and stores features, so P8/P9 later reclassify it as the ANTI-pattern (we store raw because our backbone moves)."}, {"id": "draft6_0_research_papers_phase9_maintenance_and_replay_cbrs", "label": "CBRS (class-balancing reservoir)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\maintenance-and-replay.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A drift-gated stream presents classes in bursts, so the buffer is class-imbalanced by construction; CBRS + logit-adjustment/balanced-softmax is the fix."}, {"id": "draft6_0_research_papers_phase9_maintenance_and_replay_cls", "label": "Complementary Learning Systems", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\maintenance-and-replay.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Two-store design (fast sparse hippocampus + slow cortex, replay consolidating one into the other), re-derived from the circuit side."}, {"id": "draft6_0_research_papers_phase9_maintenance_and_replay_mgser_sam", "label": "MGSER-SAM (replay x sharpness)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\maintenance-and-replay.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Replay + sharpness-aware updates; a hypothesised bridge that consolidating into a flat readout might also be consolidating into a noise-robust one \u2014 to test, not assume."}, {"id": "draft6_0_research_papers_phase9_maintenance_and_replay_probing_forgetting", "label": "Probing Representation Forgetting", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\maintenance-and-replay.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "SSL representation drift is real and measurable; don't assume the bulk is frozen-stable. Later the P9.0 instrument (a re-fit probe) that separates rotation from forgetting."}], "edges": [{"source": "draft6_0_research_papers_phase9_maintenance_and_replay", "target": "draft6_0_research_papers_phase8_the_economy_gate", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\papers\\phase9\\maintenance-and-replay.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_papers_phase9_maintenance_and_replay_experience_replay", "target": "draft6_0_src_phase9_final_architecture_maintenance_loop", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "draft6.0\\research\\papers\\phase9\\maintenance-and-replay.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_papers_phase9_maintenance_and_replay_experience_replay", "target": "draft6_0_research_papers_phase9_maintenance_and_replay_ewc", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.75, "source_file": "draft6.0\\research\\papers\\phase9\\maintenance-and-replay.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_papers_phase9_maintenance_and_replay_agem", "target": "draft6_0_research_papers_phase9_maintenance_and_replay_experience_replay", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\papers\\phase9\\mai