{"nodes": [{"id": "draft_journey_draft1_0_doc", "label": "Draft 1.0 (raw brain dump)", "file_type": "document", "source_file": "draft-journey\\draft1.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "First 7-month intuition dump: NCN/NBN/BRN/CNS/DSP/STM, scap, 2-3-3-2, constant-c backprop, encryption framing."}, {"id": "draft_journey_draft1_0_scap", "label": "scap (SRAM + Capacitor)", "file_type": "concept", "source_file": "draft-journey\\draft1.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The atom of storage: capacitor holds continuous weight magnitude, SRAM holds sign/history/refill/routing. Sign-as-digital, magnitude-as-analog. The one primitive that survived every pivot into draft 6."}, {"id": "draft_journey_draft1_0_ganglion", "label": "Ganglion (NCN, 2-3-3-2)", "file_type": "concept", "source_file": "draft-journey\\draft1.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Base compute unit; fixed 2-3-3-2 hardwired network of 29 scaps; chosen for path-diversity-per-scap, not depth/width. Dropped at the draft-6 pivot (only the path-diversity intuition carried over)."}, {"id": "draft_journey_draft1_0_column", "label": "Column (NBN, Generalist-reuse)", "file_type": "concept", "source_file": "draft-journey\\draft1.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Composition of Ganglia using the reuse pattern G->S1->G->S2->G->S3 to grow effective complexity without adding scaps."}, {"id": "draft_journey_draft1_0_limbic_loop", "label": "Limbic Loop (BRN)", "file_type": "concept", "source_file": "draft-journey\\draft1.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Recurrent two-Column system (Cortex + Hippocampus) linked by Commissure, predicting input in a clock-staggered loop."}, {"id": "draft_journey_draft1_0_commissure", "label": "Commissure (CNS)", "file_type": "concept", "source_file": "draft-journey\\draft1.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Trainable inter-Column connector at reduced learning rate; a slow-changing channel keeps the recurrent loop stable."}, {"id": "draft_journey_draft1_0_synaptic_drift", "label": "Synaptic Drift (DSP)", "file_type": "concept", "source_file": "draft-journey\\draft1.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Optional learnable 1D synapse address that scales signal by distance; position updates during backprop. Activated only after H1."}, {"id": "draft_journey_draft1_0_engram_buffer", "label": "Engram Buffer (STM)", "file_type": "concept", "source_file": "draft-journey\\draft1.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Prototype LSTM-like pure-capacitor short-term memory between Cortex and Hippocampus; deferred until the loop is stable."}, {"id": "draft_journey_draft1_0_cell_fire", "label": "Cell Fire (STDP wiring)", "file_type": "rationale", "source_file": "draft-journey\\draft1.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Group-level 'fire together, wire together' rule via spike-timing-dependent plasticity; too sensitive to formalize, left an open thread."}, {"id": "draft_journey_draft1_0_constant_c_backprop", "label": "Constant-c backprop", "file_type": "rationale", "source_file": "draft-journey\\draft1.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The original update rule: every active-path weight reduced by an equal constant c. Perceptron-era; flagged as the project's weakest link by the author himself; demoted to fallback in draft3."}, {"id": "draft_journey_draft1_0_routes_hierarchy", "label": "Routes Hierarchy (4-bit L1 x 4-bit L2)", "file_type": "concept", "source_file": "draft-journey\\draft1.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Two-level addressing giving 256 Ganglia per region; a one-time boot-load wiring model, no re-routing during operation."}, {"id": "draft_journey_draft1_0_lottery_ticket_hypothesis", "label": "Lottery Ticket Hypothesis", "file_type": "paper", "source_file": "draft-journey\\draft1.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Cited to justify Generalist reuse: each neuron has unused per-output capacity, so forcing reuse makes it allocate that capacity intentionally."}, {"id": "draft_journey_draft1_0_chronoforge", "label": "ChronoForge (FPGA game engine)", "file_type": "concept", "source_file": "draft-journey\\draft1.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Prior project: pure-hardware 2D game engine on Xilinx Basys3, 640x480@60Hz in ~18k LUTs. Proof the author ships hardware; the hardware-intuition foundation for the analog CPU."}, {"id": "draft_journey_draft1_0_fast_answer_destroys_creativity", "label": "Motto: the fast answer destroys creativity", "file_type": "rationale", "source_file": "draft-journey\\draft1.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Load-bearing methodology: build from intuition first, survey literature only after the architecture stands, to avoid inheriting digital/spiking pre-commitments."}, {"id": "draft_journey_draft1_0_prefrontal_hippocampus_loop", "label": "Recurrent prefrontal<->hippocampus loop", "file_type": "concept", "source_file": "draft-journey\\draft1.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "LSTM-flavored two-brain recurrence (hold a little, call the rest from memory, compare, halt on a feeling); the north-star lifelong loop carried from month one."}, {"id": "draft_journey_draft1_0_encryption_framing", "label": "Encryption framing (retired)", "file_type": "rationale", "source_file": "draft-journey\\draft1.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Placeholder word for on-chip weight compression (weights live only on the substrate); retired in draft3 for 'resident-weight compute / in-memory compute'."}], "edges": [{"source": "draft_journey_draft1_0_doc", "target": "draft_journey_draft1_0_scap", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft1.0.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft1_0_doc", "target": "draft_journey_draft1_0_ganglion", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft1.0.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft1_0_doc", "target": "draft_journey_draft1_0_column", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft1.0.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft1_0_doc", "target": "draft_journey_draft1_0_limbic_loop", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft1.0.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft1_0_doc", "target": "draft_journey_draft1_0_commissure", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft1.0