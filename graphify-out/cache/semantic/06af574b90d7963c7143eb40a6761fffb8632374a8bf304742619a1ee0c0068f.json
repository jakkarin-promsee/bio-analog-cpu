{"nodes": [{"id": "draft6_0_research_papers_phase6_noise_as_augmentation", "label": "Noise as contrastive augmentation \u2014 building robustness into the objective", "file_type": "document", "source_file": "draft6.0\\research\\papers\\phase6\\noise-as-augmentation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Phase 6's headline bet: the fix must be an SCFF-objective change, forward-only. Contrastive learning is invariance-injection \u2014 make the difference between paired views be device noise, and the objective trains 'same class direction under noise.'"}, {"id": "draft6_0_research_papers_phase6_noise_augmented_infonce", "label": "Noise-corrupted positive view in InfoNCE (primary fix)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase6\\noise-as-augmentation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One view clean, one tap/ADC/charge-corrupted; consistency is on the normalized embedding (an angle constraint, not magnitude) \u2014 spine-clean by construction, and the forward-only surrogate for Jacobian/Lipschitz regularization per Bishop's theorem (avoids computing the Jacobian directly, which needs backprop)."}, {"id": "draft6_0_research_papers_phase6_rince", "label": "RINCE \u2014 robust InfoNCE against noisy views", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase6\\noise-as-augmentation.md", "source_location": null, "source_url": "https://arxiv.org/abs/2201.04309", "captured_at": null, "author": null, "contributor": null, "rationale": "A loss-level drop-in robust contrastive objective provably robust to corrupted positive views \u2014 hardens the loss where augmentation hardens the inputs; P6.1 tests both, compose or RINCE-alone."}, {"id": "draft6_0_research_papers_phase6_ditch_the_denoiser", "label": "'Ditch the Denoiser' \u2014 SSL noise robustness from a curriculum", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase6\\noise-as-augmentation.md", "source_location": null, "source_url": "https://arxiv.org/abs/2505.12191", "captured_at": null, "author": null, "contributor": null, "rationale": "SSL develops genuine noise robustness from a clean-to-noisy curriculum + teacher anchor, and the denoiser is discardable at deployment (+4.8% linear probe on sigma=255 ImageNet) \u2014 robustness lives in the features not a runtime filter, exactly what an analog chip needs."}, {"id": "draft6_0_research_papers_phase6_31_confirmed_primary_fix", "label": "3.1 confirmed as primary fix, now with a name and theory", "file_type": "rationale", "source_file": "draft6.0\\research\\papers\\phase6\\noise-as-augmentation.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Adopt a noise-corrupted positive view in the InfoNCE as the headline Phase-6 objective change; sweep noise strength (too weak=no robustness, too strong=collapse); attack the structured/directional axis, not just i.i.d. Gaussian, or the wrong enemy gets hardened against."}], "edges": [{"source": "draft6_0_research_papers_phase6_noise2noise", "target": "draft6_0_research_papers_phase6_noise_as_augmentation", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.7, "source_file": "draft6.0\\research\\papers\\phase6\\noise-as-augmentation.md", "source_location": null, "weight": 0.8}, {"source": "draft6_0_research_papers_phase6_prior_favors_no_branch", "target": "draft6_0_research_papers_phase6_noise_as_augmentation", "relation": "is_resolved_toward", "confidence": "INFERRED", "confidence_score": 0.8, "source_file": "draft6.0\\research\\papers\\phase6\\noise-as-augmentation.md", "source_location": null, "weight": 0.9}, {"source": "draft6_0_research_papers_phase6_noise_as_augmentation", "target": "draft6_0_research_papers_phase6_noise_augmented_infonce", "re