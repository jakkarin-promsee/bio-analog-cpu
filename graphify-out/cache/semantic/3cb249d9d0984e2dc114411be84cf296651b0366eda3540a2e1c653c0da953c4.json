{"nodes": [{"id": "draft6_0_src_phase1_exp4_experiment_4_doc", "label": "Phase 1 Exp 4 \u2014 continual + sleep card", "file_type": "document", "source_file": "draft6.0\\src\\phase1\\exp4\\experiment-4.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": null}, {"id": "draft6_0_src_phase1_exp4_continual_sleep", "label": "Continual regime + sleep recovery", "file_type": "concept", "source_file": "draft6.0\\src\\phase1\\exp4\\experiment-4.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "On a class-incremental stream naive online learning catastrophically forgets (\u21920.18) but SCFF block + sleep recovers to the static ceiling (0.935); the prototype LUT replays nearly as well at ~1/3 the store (0.898). The architecture's validated home."}, {"id": "draft6_0_src_phase1_exp4_catastrophic_forgetting", "label": "Catastrophic forgetting (online baseline)", "file_type": "concept", "source_file": "draft6.0\\src\\phase1\\exp4\\experiment-4.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "GD-online and block-no-sleep rot to ~0.18 (chance-ish) on the class-incremental stream \u2014 the problem sleep solves."}, {"id": "draft6_0_src_phase1_exp4_scff_forgetting_robust", "label": "SCFF is forgetting-robust", "file_type": "rationale", "source_file": "draft6.0\\src\\phase1\\exp4\\experiment-4.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "SCFF's label-free density clustering just ADDS clusters for a new wave without overwriting old ones, so its all-class probe stays flat (0.90); only the small supervised readout forgets, and sleep re-fits it. The architecture's real edge and the bridge to the north star."}], "edges": [{"source": "draft6_0_src_phase1_exp4_experiment_4_doc", "target": "draft6_0_src_pha