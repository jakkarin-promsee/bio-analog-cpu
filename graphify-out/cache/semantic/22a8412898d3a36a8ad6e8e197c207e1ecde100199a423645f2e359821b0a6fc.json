{"nodes": [{"id": "draft6_0_src_stage2_design", "label": "Stage 2 Design (the GD-era plan)", "file_type": "document", "source_file": "draft6.0\\src\\stage2-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Ideas-first map of the GD namer era: boosting dropped, single frozen bulk + read-only heads, the readout learning is reservoir/ELM-like (near-convex), noise promoted out to Phase 6."}, {"id": "draft6_0_src_stage2_design_ranpac_paper", "label": "RanPAC paper (arXiv 2307.02251)", "file_type": "paper", "source_file": "draft6.0\\src\\stage2-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Frozen feats -> frozen random projection -> ridge-regularized prototype, rehearsal-free, no gradient; ridge beats plain NCM. The published near-twin the RanPAC namer implements."}, {"id": "draft6_0_src_stage2_design_lpft", "label": "LP-FT (arXiv 2202.10054)", "file_type": "paper", "source_file": "draft6.0\\src\\stage2-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A frozen head preserves but cannot manufacture the robustness the backbone lacks \u2014 the argument that noise-hardening must live in SCFF (Phase 6), not the 20% readout."}], "edges": [{"source": "draft6_0_src_stage2_design", "target": "draft6_0_idea_main_ideas_v1", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\src\\stage2-design.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_src_stage2_design", "target": "draft6_0_src_stage2_design_lpft", "relation": "cites", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\src\\stage2-design.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_src_stage2_design", "target": "draft6_0_src_stage2_design_ranpac_paper", "relation": "cite