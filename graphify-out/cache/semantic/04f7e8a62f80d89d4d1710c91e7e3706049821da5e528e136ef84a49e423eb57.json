{"nodes": [{"id": "draft_journey_draft4_0_x1_doc", "label": "Draft 4.0.x1 (external-critique brainstorm)", "file_type": "document", "source_file": "draft-journey\\draft4.0.x1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The four architectural holes and their fixes: Forward_Sign_SRAM, Physical Saturation, Range Sensitivity, analog robustness (differential pair/dummy scap/current mirror/auto-zeroing/ping-pong)."}, {"id": "draft_journey_draft4_0_x1_forward_sign_sram", "label": "Forward_Sign_SRAM (per-scap direction)", "file_type": "concept", "source_file": "draft-journey\\draft4.0.x1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "1-bit per scap latching input_sign XOR weight_sign at forward time so a scap remembers which way it pushed; direction = Forward_Sign XOR feedback. Resolves multi-parent direction conflict but is degenerate under ReLU (H11)."}, {"id": "draft_journey_draft4_0_x1_physical_saturation", "label": "Physical Saturation (WTA defense)", "file_type": "rationale", "source_file": "draft-journey\\draft4.0.x1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The weight cap's hard supply-rail ceiling self-limits (dV/dt -> 0 near the rail): L2 regularization implemented in physics, the architecture's answer to winner-take-all / activity-vs-relevance (H10)."}, {"id": "draft_journey_draft4_0_x1_range_sensitivity", "label": "Range Sensitivity (Programmable Gain Amplifier)", "file_type": "concept", "source_file": "draft-journey\\draft4.0.x1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Switchable op-amp gain (1x/10x/100x via resistor ladder) to discriminate tiny currents during deep convergence; triggered globally by Brainstem or locally when >80% of scaps clip at T_max. Analog automatic gain control."}, {"id": "draft_journey_draft4_0_x1_analog_robustness", "label": "Analog Robustness Mechanisms (PVT defenses)", "file_type": "concept", "source_file": "draft-journey\\draft4.0.x1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Baseline defenses against PVT drift: Differential Pair op-amps (common-mode cancel), Dummy Scap (on-the-fly calibration), Current Mirror loss-share (ratio preservation), Auto-Zeroing phases, optional Ping-Pong substrate."}, {"id": "draft_journey_draft4_0_x1_multi_parent_conflict", "label": "Multi-parent direction conflict (logic hole)", "file_type": "rationale", "source_file": "draft-journey\\draft4.0.x1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "In the Lobe DAG, summing shares handles magnitude but loses direction when parents disagree; the global feedback carries one sign. Fixed by Forward_Sign_SRAM."}, {"id": "draft_journey_draft4_0_x1_activity_vs_relevance", "label": "Activity vs Relevance gap (algorithmic hole)", "file_type": "rationale", "source_file": "draft-journey\\draft4.0.x1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "High |a*W| activity does not equal high relevance to the loss; a very active but cancelled scap still claims a large share while long-tail relevant features under-update. Defended primarily by Physical Saturation."}], "edges": [{"source": "draft_journey_draft4_0_x1_doc", "target": "draft_journey_draft4_0_doc", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft4.0.x1.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft4_0_x1_doc", "target": "draft_journey_draft4_0_x1_forward_sign_sram", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft4.0.x1.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft4_0_x1_doc", "target": "draft_journey_draft4_0_x1_physical_saturation", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft4.0.x1.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft4_0_x1_doc", "target": "draft_journey_draft4_0_x1_range_sensitivity", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft4.0.x1.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft4_0_x1_doc", "target": "draft_journey_draft4_0_x1_analog_robustness", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft4.0.x1.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft4_0_x1_doc", "target": "draft_journey_draft4_0_x1_multi_parent_conflict", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft4.0.x1.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft4_0_x1_doc", "target": "draft_journey_draft4_0_x1_activity_vs_relevance", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft4.0.x1.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft4_0_x1_doc", "target": "draft_journey_draft4_0_tunable_weight_decay", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft4.0.x1.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft4_0_x1_forward_sign_sram", "target": "draft_journey_draft4_0_x1_multi_parent_conflict", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft4.0.x1.md", "source_location": null, "weight": 1.0}, {"source": "d