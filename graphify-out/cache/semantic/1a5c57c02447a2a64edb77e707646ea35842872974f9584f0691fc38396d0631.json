{"nodes": [{"id": "draft6_0_research_north_star_th_21_energy", "label": "North-star 21 \u2014 The Energy View (capstone)", "file_type": "document", "source_file": "draft6.0\\research\\north-star\\th\\21-energy.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Capstone: one principle unifies half the dossier \u2014 inference = roll downhill, learning = sculpt the valley; under it lies Landauer's floor making settle-not-erase the physically cheapest path."}, {"id": "draft6_0_research_north_star_th_21_energy_ebm", "label": "Energy-Based Learning (EBM)", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\21-energy.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "LeCun et al. 2006: scalar E(x,y), no normalization needed; SCFF is an EBM that solves negative-sampling via augmentation (no MCMC), trainable forward-only."}, {"id": "draft6_0_research_north_star_th_21_energy_contrastive_divergence", "label": "Contrastive Divergence", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\21-energy.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hinton 2002: run MCMC only K steps for negatives; still approximate/slow \u2014 SCFF's augmentation trick is the more elegant negative source."}, {"id": "draft6_0_research_north_star_th_21_energy_landauer", "label": "Landauer's principle", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\21-energy.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Landauer 1961 / Bennett 1973: erasing a bit costs kT ln2; resident-weight (no erase), compute-in-memory (no bit-move), continuous settling (no bit-flip) approach the limit like the brain \u2014 100-1000x below CPU."}, {"id": "draft6_0_research_north_star_th_21_energy_energy_principle", "label": "Energy-shaping machine (unifying principle)", "file_type": "rationale", "source_file": "draft6.0\\research\\north-star\\th\\21-energy.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "SCFF goodness, Hopfield, EqProp, predictive coding, Lyapunov, diffusion score are all energy descent in different clothes; the chip computes by flowing down a landscape it never erases."}], "edges": [{"source": "draft6_0_research_north_star_th_21_energy", "target": "draft6_0_research_north_star_th_21_energy_ebm", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\21-energy.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_21_energy", "target": "draft6_0_research_north_star_th_21_energy_contrastive_divergence", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\21-energy.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_21_energy", "target": "draft6_0_research_north_star_th_21_energy_landauer", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\21-energy.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_21_energy", "target": "draft6_0_research_north_star_th_21_energy_energy_principle", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\21-energy.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_21_energy", "target": "draft6_0_research_papers_phase1_2_scff", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\21-ene