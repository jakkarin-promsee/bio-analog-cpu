{"nodes": [{"id": "docs_essence_the_essence2_doc", "label": "The Essence, After the World (draft 6.0)", "file_type": "document", "source_file": "docs\\essence\\the-essence2.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The grown spine after ten phases; Part I the spine, Part II the full record. Numbers as evidence, not hero."}, {"id": "docs_essence_the_essence2_copy_function_cheat_implementation", "label": "Copy the function, cheat the implementation", "file_type": "rationale", "source_file": "docs\\essence\\the-essence2.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The load-bearing method: copy what the brain does, pay for each principle with whatever is cheap on the substrate (analog physics where physics is cheaper, modern math where math is cheaper). Licenses SCFF/GD/boosting; not a betrayal of biology, the only honest road to it."}, {"id": "docs_essence_the_essence2_density_not_class", "label": "density != class (the villain's disguise)", "file_type": "rationale", "source_file": "docs\\essence\\the-essence2.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "An unsupervised learner organizes by density (a magnitude) but the label lives in a direction; the cheap machine keeps grabbing density and calling it understanding. Met at least eight times across the phases."}, {"id": "docs_essence_the_essence2_direction_expensive", "label": "Direction is the expensive thing (magnitude is a decoy)", "file_type": "rationale", "source_file": "docs\\essence\\the-essence2.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The one invariant: information lives in which-way; how-much the physics hands you free (forward-only). You cannot get direction without paying for it. The recurring killer and the recurring key; pay for direction once, make everything else cheap."}], "edges": [{"source": "docs_essence_the_essence2_doc", "target": "docs_essence_the_essence_doc", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs\\essence\\the-essence2.md", "source_location": null, "weight": 1.0}, {"source": "docs_essence_the_essence2_doc", "target": "docs_essence_the_essence2_copy_function_cheat_implementation", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs\\essence\\the-essence2.md", "source_location": null, "weight": 1.0}, {"source": "docs_essence_the_essence2_doc", "target": "docs_essence_the_essence2_density_not_class", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs\\essence\\the-essence2.md", "source_location": null, "weight": 1.0}, {"source": "docs_essence_the_essence2_doc", "target": "docs_essence_the_essence2_direction_expensive", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs\\essence\\the-essence2.md", "source_location": null, "weight": 1.0}, {"source": "docs_essence_the_essence2_doc", "target": "docs_draft_project_history_scff", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs\\essence\\the-essence2.md", "source_location": null, "weight": 1.0}, {"source": "docs_essence_the_essence2_doc", "target": "docs_draft_project_history_draft6_scff_gd_rebuild", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs\\essence\\the-essence2.md", "source_location": null, "weight": 1.0}, {"source": "docs_essence_the_essence2_doc", "target": "docs_essence_the_essence_draft5_collapse", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs\\essence\\the-essence2.md", "source_location": null, "weight": 1.0}, {"source": "docs_essence_the_e