{"nodes": [{"id": "draft6_0_research_north_star_th_2_controller", "label": "North-star 2 \u2014 Prefrontal / Working Memory / Coordinator", "file_type": "document", "source_file": "draft6.0\\research\\north-star\\th\\2-controller.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Prefrontal = a small bandwidth-limited coordinator that holds little, queries memory, broadcasts a summary; scarcity is the feature that forces specialization."}, {"id": "draft6_0_research_north_star_th_2_controller_gwt", "label": "Global Workspace Theory", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\2-controller.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Baars 1988 / Dehaene 2011: competition + ignition + broadcast; capacity ~4; bandwidth limit is a feature; analog = WTA competition + one-to-many broadcast bus."}, {"id": "draft6_0_research_north_star_th_2_controller_shared_gw", "label": "Shared Global Workspace (Bengio)", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\2-controller.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Goyal et al. ICLR 2022: buildable GWT \u2014 specialist modules write to a few-slot workspace via attention, broadcast back; bottleneck forces modularity; answers 'how do the brains communicate'."}, {"id": "draft6_0_research_north_star_th_2_controller_rims", "label": "Recurrent Independent Mechanisms", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\2-controller.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Goyal et al. 2019: K small recurrent units, top-k active, rest frozen; sleeping module = zero energy on analog; SCFF blocks = RIM units."}, {"id": "draft6_0_research_north_star_th_2_controller_consciousness_prior", "label": "The Consciousness Prior", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\2-controller.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Bengio 2017: thought = low-dim sparse projection of high-dim state; workspace narrowness is a learning constraint; send SCFF centroids (8-16 dims) not raw 100-unit activations."}, {"id": "draft6_0_research_north_star_th_2_controller_pbwm", "label": "PBWM gating (basal-ganglia WM)", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\2-controller.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "O'Reilly & Frank 2006: learned Go/No-Go gates trained by TD error decide what enters/clears working memory; biological parent of the LSTM gate; analog = a voltage-controlled transmission gate."}], "edges": [{"source": "draft6_0_research_north_star_th_2_controller", "target": "draft6_0_research_north_star_th_2_controller_gwt", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\2-controller.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_2_controller", "target": "draft6_0_research_north_star_th_2_controller_shared_gw", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\2-controller.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_2_controller", "target": "draft6_0_research_north_star_th_2_controller_rims", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\2-controller.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_2_controller", "target": "draft6_0_r