{"nodes": [{"id": "draft6_0_research_papers_phase9_deep_research_delta", "label": "Phase 9 deep-research delta", "file_type": "document", "source_file": "draft6.0\\research\\papers\\phase9\\deep-research-delta.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": null}, {"id": "draft6_0_research_papers_phase9_deep_research_delta_rotation_vs_destruction", "label": "Rotation vs destruction (P9.0 risk gate)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\deep-research-delta.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Split the two things the cheapness story conflates: bulk_drift cosine (rotation, sleep fixes cheaply) vs a frozen-early-task probe re-scored on the current bulk (destruction). Continuous SSL DOES forget, so this is a real risk gate not a warm-up."}, {"id": "draft6_0_research_papers_phase9_deep_research_delta_continuous_ssl_forgets", "label": "Continuous SSL forgets (CaSSLe / revisiting supervision)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\deep-research-delta.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "SSL forgets differently, not universally less; 'SCFF doesn't forget' is a claim about our objective on our stream, not a free inheritance."}, {"id": "draft6_0_research_papers_phase9_deep_research_delta_ldc", "label": "LDC (Learnable Drift Compensation)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\deep-research-delta.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Learnable projector mapping consecutive feature spaces (rotation+scaling), exemplar-free, any moving backbone; the correctly-named road-not-taken vs our sleep re-forward (a new trained organ, deferred)."}, {"id": "draft6_0_research_papers_phase9_deep_research_delta_latent_replay", "label": "Latent Replay (consolidation depth)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\deep-research-delta.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Replay at a chosen mid-network layer: slow below, learn above; couples P9.2 to P9.1 (slow below the read layer = the latent-replay recipe)."}, {"id": "draft6_0_research_papers_phase9_deep_research_delta_dcbrs", "label": "D-CBRS (intra-class diversity)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\deep-research-delta.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Fixes CBRS collapsing intra-class diversity; a conditional refinement arm \u2014 but P7 found features unimodal so plain CBRS is expected winner."}, {"id": "draft6_0_research_papers_phase9_deep_research_delta_prototype_shift", "label": "Test-time prototype shift (feature-level calibration)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase9\\deep-research-delta.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Scalar temperature scaling is ineffective under shift; a directional input-transducer shift needs a feature/prototype-level re-estimation, direction-grounded not a confidence magnitude."}], "edges": [{"source": "draft6_0_research_papers_phase9_deep_research_delta", "target": "draft6_0_research_papers_phase9_readme", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\papers\\phase9\\deep-research-delta.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_papers_phase9_deep_research_delta", "target": "draft6_0_research_papers_phase8_deep_research_delta", "relation": "references", "confide