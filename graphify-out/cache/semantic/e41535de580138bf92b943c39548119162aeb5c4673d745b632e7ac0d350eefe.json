{"nodes": [{"id": "draft6_0_research_north_star_10_realtime", "label": "north-star 10 - realtime forward + learning", "file_type": "document", "source_file": "draft6.0\\research\\north-star\\10-realtime.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Drop BPTT; realtime learning = local forward traces x teaching signal; RTRL ideal, e-prop the tractable on-chip form, liquid nets for realtime inference, reservoirs cheapest, SSM/Mamba the modern proof."}, {"id": "draft6_0_research_north_star_10_realtime_rtrl", "label": "RTRL (Real-Time Recurrent Learning)", "file_type": "paper", "source_file": "draft6.0\\research\\north-star\\10-realtime.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Exact online forward-only gradient via an influence matrix - learn after every input, no history, no backward pass; but O(n^3) memory/O(n^4) compute, tractable only when sparse/local (the substrate). The ideal that e-prop approximates."}, {"id": "draft6_0_research_north_star_10_realtime_e_prop", "label": "e-prop (eligibility trace x learning signal)", "file_type": "paper", "source_file": "draft6.0\\research\\north-star\\10-realtime.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Bellec et al. 2020: the tractable on-chip RTRL - factorizes the gradient into a per-synapse eligibility trace (forward) x a broadcast learning signal; the single most relevant paper for realtime learning. The trace is a leaky cap the Scap already has; almost exactly draft-6's local SCFF + broadcast correction."}, {"id": "draft6_0_research_north_star_10_realtime_reservoir_computing", "label": "Reservoir computing (train only the readout)", "file_type": "paper", "source_file": "draft6.0\\research\\north-star\\10-realtime.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Fix a random recurrent reservoir, train only a linear readout (one-shot regression); realtime inference and learning with no backprop. The cheapest realtime path - let the messy analog dynamics be the reservoir (mismatch is a feature)."}, {"id": "draft6_0_research_north_star_10_realtime_liquid_networks", "label": "Liquid networks (continuous-time ODE atoms)", "file_type": "paper", "source_file": "draft6.0\\research\\north-star\\10-realtime.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Liquid Time-Constant / CfC nets: continuous-time ODE neurons with adaptive time-constants, inherently realtime inference (19 neurons -> car control). The realtime inference substrate that pairs with e-prop learning."}, {"id": "draft6_0_research_north_star_10_realtime_snn_neuromorphic", "label": "Spiking nets / neuromorphic hardware (Loihi, SpiNNaker)", "file_type": "paper", "source_file": "draft6.0\\research\\north-star\\10-realtime.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Event-driven sparse spikes: a unit costs nothing until it fires; on-chip learning via e-prop-style local rules. The project's nearest neighbor in intent - steal 'event-driven = compute only on change' (the sparse property taken to its limit)."}, {"id": "draft6_0_research_north_star_10_realtime_ssm_mamba", "label": "State-Space Models / Mamba", "file_type": "paper", "source_file": "draft6.0\\research\\north-star\\10-realtime.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "dx/dt=Ax+Bu discretized = trainable analog filters; O(1)-per-step streaming recurrent inference at linear cost. The modern proof that continuous-time linear dynamics - literally the substrate - are the efficient way to do sequences."}], "edges": [{"source": "draft6_0_research_nort