{"nodes": [{"id": "draft6_0_research_north_star_th_18_analog_noise", "label": "North-star 18 \u2014 Analog Noise & Temperature", "file_type": "document", "source_file": "draft6.0\\research\\north-star\\th\\18-analog-noise.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Circuit truth: match technique to noise TIMESCALE \u2014 slow noise subtract (vs reference), fast noise average (over time/copies); draft-5 \u00a715 already speced 3/4 of the fixes."}, {"id": "draft6_0_research_north_star_th_18_analog_noise_ktc", "label": "kT/C thermal noise", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\18-analog-noise.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Johnson/Nyquist 1928: V_rms=sqrt(kT/C), physics-mandated weight noise floor; three knobs \u2014 bigger C, average, or train against it (Bishop)."}, {"id": "draft6_0_research_north_star_th_18_analog_noise_flicker_offset", "label": "1/f flicker noise & offset", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\18-analog-noise.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Slow enemies from device traps and transistor mismatch; low-frequency, killed by chopper/auto-zero, not by differential alone."}, {"id": "draft6_0_research_north_star_th_18_analog_noise_differential", "label": "Differential signaling / common-mode rejection", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\18-analog-noise.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Razavi 2001: temperature drift is common-mode, cancels in the difference (CMRR>80dB); draft-5 \u00a715 differential-pair does exactly this; fully-differential weight = matching, not absolute accuracy."}, {"id": "draft6_0_research_north_star_th_18_analog_noise_chopper", "label": "Chopper stabilization", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\18-analog-noise.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Enz & Temes 1996: modulate up to f_c, amplify, demodulate \u2014 kills 1/f and offset; good for slow precision weight-update, not fast inference (ripple/latency)."}, {"id": "draft6_0_research_north_star_th_18_analog_noise_autozero", "label": "Auto-zeroing", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\18-analog-noise.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Measure offset then subtract; draft-5 \u00a715 'auto-zeroing' is exactly this; cheapest for duty-cycled MVM bursts."}, {"id": "draft6_0_research_north_star_th_18_analog_noise_dummy_cell", "label": "Dummy / reference cell", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\18-analog-noise.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A twin Scap that drifts together, subtract it out; draft-5 \u00a715 'Dummy Scap' + current mirror; the temperature problem is 3/4 solved in the author's own draft-5."}, {"id": "draft6_0_research_north_star_th_18_analog_noise_noise_aware_training", "label": "Noise-aware / variation-aware training", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\18-analog-noise.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Inject simulated hardware noise during training (Bishop's theorem); 88-90% deploy accuracy on real RRAM vs 71% without; three-layer split circuit->architecture->training."}], "edges": [{"source": "draft6_0_research_north_star_th_18_analog_noise", "target": "draft6_0_research_