{"nodes": [{"id": "draft6_0_research_north_star_th_7_encoding", "label": "North-star 7 \u2014 Input/Output Shape & Don't Self-Delude", "file_type": "document", "source_file": "draft6.0\\research\\north-star\\th\\7-encoding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Representation problem: 'self-delusion' = collapse + shortcut learning; menu of honest low-label encodings; bites draft-6.0 NOW because all of SCFF is encoding."}, {"id": "draft6_0_research_north_star_th_7_encoding_vicreg", "label": "VICReg", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\7-encoding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Bardes/Ponce/LeCun 2022: explicit anti-collapse via variance+invariance+covariance; variance/covariance are running statistics friendly to leaky capacitors + crossbar outer products."}, {"id": "draft6_0_research_north_star_th_7_encoding_barlow_twins", "label": "Barlow Twins", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\7-encoding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Zbontar et al. 2021: cross-correlation matrix -> identity (redundancy reduction, Barlow 1961); the C matrix = one crossbar sweep; decorrelation is PVT robustness in disguise."}, {"id": "draft6_0_research_north_star_th_7_encoding_mae_ijepa", "label": "MAE vs I-JEPA", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\7-encoding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "He 2022 vs Assran 2023: predicting representation (I-JEPA) beats predicting pixel (MAE), gap widens with fewer labels; don't add input-reconstruction loss to SCFF."}, {"id": "draft6_0_research_north_star_th_7_encoding_sparse_coding", "label": "Sparse coding / SDR", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\7-encoding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Olshausen & Field 1996 / Numenta SDR: sparsity yields edge detectors, huge capacity, noise tolerance, similarity-by-overlap; SDR properties map directly to PVT tolerance and LUT matching; add k-WTA to set sparsity."}, {"id": "draft6_0_research_north_star_th_7_encoding_vqvae", "label": "VQ-VAE", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\7-encoding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "van den Oord 2017: snap to nearest codeword (EMA-updated) = learnable LUT + discretization-as-error-correction; nearest-match = one crossbar sweep; sleep = periodic VQ step."}, {"id": "draft6_0_research_north_star_th_7_encoding_information_bottleneck", "label": "Information Bottleneck", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\7-encoding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tishby et al. 1999: good representation = min I(X;Z) while keeping I(Z;Y); precise definition of self-delusion \u2014 shortcut = high I(X;Z), collapse = low I(Z;Y); add L1 on activations to approximate."}], "edges": [{"source": "draft6_0_research_north_star_th_7_encoding", "target": "draft6_0_research_north_star_th_7_encoding_vicreg", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\7-encoding.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_7_encoding", "target": "draft6_0_research_north_star_th_7_encoding_barlow_twins", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\