{"nodes": [{"id": "draft_journey_draft3_0_doc", "label": "Draft 3.0 (distribution-measurement rewrite)", "file_type": "document", "source_file": "draft-journey\\draft3.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Central learning mechanism replaced: distribution-weighted local update, decentralized backprop, encryption->resident-weight compute."}, {"id": "draft_journey_draft3_0_distribution_measurement", "label": "Distribution measurement (|a*W| forward byproduct)", "file_type": "rationale", "source_file": "draft-journey\\draft3.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each scap measures its own forward-pass contribution (current is a*W, measured for free) via time-to-threshold on a measurement cap. Called 'the greatest progress of our model'; what made attribution-based learning possible."}, {"id": "draft_journey_draft3_0_momentum_sram", "label": "Momentum SRAM (16-bit EMA)", "file_type": "concept", "source_file": "draft-journey\\draft3.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "16-bit per-scap SRAM accumulating contribution across batches with shift-friendly EMA (alpha=3/4); floor-at-1 prevents dead-scap collapse. Replaces draft2's 1-bit history."}, {"id": "draft_journey_draft3_0_pwm_update", "label": "PWM update", "file_type": "rationale", "source_file": "draft-journey\\draft3.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Pulse-width-modulated capacitor charge transfer written locally per scap; direction = sign XOR feedback, magnitude = pulse_width x momentum. The decentralization win: all scaps update in parallel on one broadcast pulse."}, {"id": "draft_journey_draft3_0_time_to_threshold", "label": "Time-to-threshold measurement", "file_type": "rationale", "source_file": "draft-journey\\draft3.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Clock-count for a measurement cap to cross A%->B%, referenced against a calibration cap (ratio measurement, PVT-robust); runs free in the output-charge window. Steeper rise = stronger contribution."}, {"id": "draft_journey_draft3_0_decentralized_backprop", "label": "Decentralized backprop (broadcast pulse)", "file_type": "rationale", "source_file": "draft-journey\\draft3.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Master computes one scalar loss, broadcasts a single pulse; every scap updates locally from its stored momentum. No per-scap gradient routing. Evolved into hierarchical diffusion in draft3.1."}, {"id": "draft_journey_draft3_0_reservoir_g", "label": "Reservoir-G (frozen Generalist fallback)", "file_type": "rationale", "source_file": "draft-journey\\draft3.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Fallback if Generalist-reuse collisions degrade training: freeze G with diverse random weights (reservoir/echo-state computing); all learning in the Specialists."}, {"id": "draft_journey_draft3_0_resident_weight_compute", "label": "Resident-weight compute (in-memory compute / CIM)", "file_type": "concept", "source_file": "draft-journey\\draft3.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Committed property: weights never leave the substrate during operation, only serialized at shutdown; storage and compute are the same hardware. The technical replacement for the retired 'encryption' framing."}, {"id": "draft_journey_draft3_0_floating_gate_storage", "label": "Floating-gate transistor storage (future track)", "file_type": "concept", "source_file": "draft-journey\\draft3.0.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "NAND-flash-style analog storage (Mythic AI's choice) holding charge for years without refresh; deferred until refresh is shown to do real work."}], "edges": [{"source": "draft_journey_draft3_0_doc", "target": "draft_journey_draft2_0_doc", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft3.0.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft3_0_doc", "target": "draft_journey_draft3_0_distribution_measurement", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft3.0.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft3_0_doc", "target": "draft_journey_draft3_0_momentum_sram", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft3.0.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft3_0_doc", "target": "draft_journey_draft3_0_pwm_update", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft3.0.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft3_0_doc", "target": "draft_journey_draft3_0_time_to_threshold", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft3.0.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft3_0_doc", "target": "draft_journey_draft3_0_decentralized_backprop", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft3.0.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft3_0_doc", "target": "draft_journey_draft3_0_reservoir_g", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "