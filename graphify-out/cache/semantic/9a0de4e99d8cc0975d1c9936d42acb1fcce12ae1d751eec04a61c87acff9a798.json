{"nodes": [{"id": "draft6_0_research_north_star_th_20_dynamics", "label": "North-star 20 \u2014 Dynamics & Stability", "file_type": "document", "source_file": "draft6.0\\research\\north-star\\th\\20-dynamics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The chip is a physical dynamical system that settles; question is 'does it converge/oscillate/explode' \u2014 answerable and DESIGNABLE (Lyapunov/contraction/edge-of-chaos/attractors)."}, {"id": "draft6_0_research_north_star_th_20_dynamics_lyapunov", "label": "Lyapunov stability", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\20-dynamics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Lyapunov 1892: a dissipative analog circuit has total charge energy as a built-in Lyapunov function that always decreases -> settling proven from physics; Hopfield designs E so patterns are minima."}, {"id": "draft6_0_research_north_star_th_20_dynamics_contraction", "label": "Contraction theory", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\20-dynamics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Lohmiller & Slotine 1998: bounded spectral norm + leakage -> unique equilibrium, global exponential convergence, noise forgotten; one constraint (spectral norm) gives stability + robustness + generalization."}, {"id": "draft6_0_research_north_star_th_20_dynamics_edge_of_chaos", "label": "Edge of chaos / Lyapunov exponents", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\20-dynamics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "lambda~0 is the sweet spot: expressive yet stable; tune via crossbar gain, leakage rate, residual skip weight; verify effective lambda near 0 vs depth in sim."}, {"id": "draft6_0_research_north_star_th_20_dynamics_attractor", "label": "Attractors as computation", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\20-dynamics.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hopfield: classification/recall/decision = settling into a basin; every settle cleans noise for free; basin width = designable noise budget shaped by training."}], "edges": [{"source": "draft6_0_research_north_star_th_20_dynamics", "target": "draft6_0_research_north_star_th_20_dynamics_lyapunov", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\20-dynamics.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_20_dynamics", "target": "draft6_0_research_north_star_th_20_dynamics_contraction", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\20-dynamics.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_20_dynamics", "target": "draft6_0_research_north_star_th_20_dynamics_edge_of_chaos", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\20-dynamics.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_20_dynamics", "target": "draft6_0_research_north_star_th_20_dynamics_attractor", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\20-dynamics.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_20_dynamics", "target": "draft6_0_research_north_star_th_3_recurrence", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\