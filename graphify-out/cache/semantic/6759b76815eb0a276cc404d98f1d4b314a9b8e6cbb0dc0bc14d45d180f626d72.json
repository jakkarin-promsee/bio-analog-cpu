{"nodes": [{"id": "draft6_0_research_papers_phase3_direction1", "label": "Direction 1 \u2014 cross-layer goodness (A1-from-layer-2)", "file_type": "document", "source_file": "draft6.0\\research\\papers\\phase3\\direction-1-cross-layer-goodness.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The author's cross-layer goodness idea already has a name \u2014 Overlapping Local Updates (OLU) from The Trifecta \u2014 a cheap, forward-computed one-step lookahead coordination signal; adopted as the coordination window, verdict: cheap first probe, modest gain alone."}, {"id": "draft6_0_research_papers_phase3_olu", "label": "Overlapping Local Updates (OLU) / The Trifecta", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase3\\direction-1-cross-layer-goodness.md", "source_location": null, "source_url": "https://arxiv.org/abs/2311.18130", "captured_at": null, "author": null, "contributor": null, "rationale": "Trains layers in overlapping pairs; a layer updated to help the next layer's goodness = the author's A1*(sum B) proposal re-derived; gain is real but modest \u2014 batch-norm does the heavy lifting on the depth curve in the source paper, OLU is a smaller add-on."}, {"id": "draft6_0_research_papers_phase3_layer_collaboration_broadcast", "label": "Layer Collaboration broadcast (gamma scalar)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase3\\direction-1-cross-layer-goodness.md", "source_location": null, "source_url": "https://arxiv.org/abs/2305.12393", "captured_at": null, "author": null, "contributor": null, "rationale": "Each layer's loss adds the detached total goodness of all other layers (one scalar broadcast ~ a neuromodulator); stays local, weaker than OLU (scalar not directional) but cheaper."}, {"id": "draft6_0_research_papers_phase3_direct_feedback_topdown", "label": "Direct feedback / top-down (constant-width paper)", "file_type": "concept", "source_file": "draft6.0\\research\\papers\\phase3\\direction-1-cross-layer-goodness.md", "source_location": null, "source_url": "https://arxiv.org/abs/2601.21683", "captured_at": null, "author": null, "contributor": null, "rationale": "Uses the top layer's activations as a reference for all lower layers \u2014 stronger (global) coordination than a 2-layer window, still forward-only broadcast not a backward gradient; cousin of Direct Feedback Alignment."}, {"id": "draft6_0_research_papers_phase3_myopia_diagnosis", "label": "The myopia diagnosis (local algorithms can't communicate upward)", "file_type": "rationale", "source_file": "draft6.0\\research\\papers\\phase3\\direction-1-cross-layer-goodness.md", "source_location": null, "source_url": "https://arxiv.org/abs/2012.03837", "captured_at": null, "author": null, "contributor": null, "rationale": "'Local algorithms fail because there is no mechanism for higher layers to communicate with lower layers' \u2014 this sentence IS the Phase-2 wall, in the wider local-learning literature's own words."}], "edges": [{"source": "draft6_0_research_papers_phase1_2_df_o_r", "target": "draft6_0_research_papers_phase3_olu", "relation": "same_family_as", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "draft6.0\\research\\papers\\phase3\\direction-1-cross-layer-goodness.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_papers_phase3_direction1", "target": "draft6_0_research_papers_phase3_olu", "relation": "identifies_as", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\papers\\phase3\\direction-1-cross-layer-goodness.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_papers_phase3_direction1", "target": "draft6_0_research_papers_phase3_layer_collaboration_broadcast", "relation": "discusses", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\papers\\phase3\\direction-1-cross-layer-goodness.