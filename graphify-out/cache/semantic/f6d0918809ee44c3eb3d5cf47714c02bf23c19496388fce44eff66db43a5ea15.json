{"nodes": [{"id": "draft6_0_src_phase1_exp0_figs_exp0_f1_learning", "label": "F1 learning curve \u2014 SCFF vs full-GD (checkerboard)", "file_type": "image", "source_file": "draft6.0\\src\\phase1\\exp0\\figs_exp0\\F1_learning.png", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Line chart, held-out accuracy vs samples-seen (log x, 1..~5x10^4), n=5, 2-D 16-cluster checkerboard. SCFF+linear-probe (teal) starts near 0.82 with almost no training and plateaus ~0.80; full-GD (orange) starts at chance (~0.49), crosses SCFF around ~300 samples, and climbs to a 0.94 ceiling. This is the cheap-instant-but-capped vs expensive-but-precise trade that opens Phase 1, embedded verbatim in phase1-report.md as 'the cheap-vs-precise crossover'."}], "edges": [{"source": "draft6_0_src_phase1_exp0_figs_exp0_f1_learning", "target": "draft6_0_src_phase1_phase1_report", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\src\\phase1\\exp0\\figs_exp0\\F1_learning.png", "source_location": null, "weight": 1.0}, {"source": "draft6_0_src_phase1_exp0_figs_exp0_f1_learning", "target": "draft6_0_src_phase1_exp0_experiment_0_doc", "relation": "references", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "draft6.0\\src\\phase1\\exp0\\figs_exp0\\F1_learning.png", "source_location": null, "weight": 1.0}, {"source": "draft6_0_src_phase1_exp0_figs_exp0_f1_learning", "target": "draft6_0_src_phase1_exp0_scff_gate", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "draft6.0\\src\\phase1\\exp0\\figs_exp0\\F1_learning.png", "source_location": null, "weight": 1.0}], "hyperedges": [{"id": "phase1_scff_gate_figure_bundle", "label": "SCFF sanity-gate figure bundle (exp0 default run + standalone gate script)", "nodes": ["draft6_0_src_phase1_exp0_figs_exp0_f1_learning", "draft6_0_src_phase1_exp0_figs_exp0_f3_separability