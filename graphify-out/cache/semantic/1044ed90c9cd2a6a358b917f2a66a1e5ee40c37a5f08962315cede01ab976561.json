{"nodes": [{"id": "draft6_0_research_north_star_th_15_convolution", "label": "North-star 15 \u2014 Convolution + SCFF", "file_type": "document", "source_file": "draft6.0\\research\\north-star\\th\\15-convolution.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tier-1: conv works with SCFF (cleaner unsupervised), use only where spatial/translation structure exists; the Ganglion linear-projection collapse = 1x1 conv, keep it."}, {"id": "draft6_0_research_north_star_th_15_convolution_conv_scff", "label": "Convolutional SCFF", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\15-convolution.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Sci Reports 2025 / Channel-Wise Goodness; being unsupervised skips the label-tiling headache of supervised conv-FF; SCFF paper hits 80.75% CIFAR-10 with CNN."}, {"id": "draft6_0_research_north_star_th_15_convolution_convolution", "label": "Convolution (weight sharing + locality)", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\15-convolution.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Weight sharing pushed to the limit = translation equivariance; the compression principle specialized to spatial data \u2014 one kernel reused everywhere."}, {"id": "draft6_0_research_north_star_th_15_convolution_depthwise_separable", "label": "Depthwise-separable convolution", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\15-convolution.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "MobileNet: depthwise (local per channel = mechanism A) + pointwise (channel mix = mechanism B); the author re-derived MobileNet's core trick from the Ganglion intuition."}, {"id": "draft6_0_research_north_star_th_15_convolution_pointwise_conv", "label": "1x1 / pointwise convolution", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\15-convolution.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Network-in-Network / Inception / ResNet bottleneck; the Ganglion 'collapse via linear projection' IS this \u2014 a learned channel projection/bottleneck. Keep it, reframe (retire the draft-5 axon rationale)."}, {"id": "draft6_0_research_north_star_th_15_convolution_johnson_lindenstrauss", "label": "Johnson\u2013Lindenstrauss projection", "file_type": "concept", "source_file": "draft6.0\\research\\north-star\\th\\15-convolution.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Random linear projection preserves pairwise distances; even a fixed random 1x1 projection keeps geometry \u2014 the collapse is principled, and it's the reservoir random projection."}], "edges": [{"source": "draft6_0_research_north_star_th_15_convolution", "target": "draft6_0_research_north_star_th_15_convolution_conv_scff", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\15-convolution.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_15_convolution", "target": "draft6_0_research_north_star_th_15_convolution_convolution", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\15-convolution.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_research_north_star_th_15_convolution", "target": "draft6_0_research_north_star_th_15_convolution_depthwise_separable", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\research\\north-star\\th\\15-convolution.md", "source_locatio