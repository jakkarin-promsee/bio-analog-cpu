{"nodes": [{"id": "draft6_0_src_phase1_exp1_experiment_1_doc", "label": "Phase 1 Exp 1 \u2014 block vs pure GD card", "file_type": "document", "source_file": "draft6.0\\src\\phase1\\exp1\\experiment-1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": null}, {"id": "draft6_0_src_phase1_exp1_memorization_gap", "label": "Memorization gap (block understands, GD memorizes)", "file_type": "concept", "source_file": "draft6.0\\src\\phase1\\exp1\\experiment-1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "On MNIST the block's train\u2212held gap is +0.027 vs GD +0.062 (disjoint IQR, 5/5): SCFF's unsupervised features can't encode label noise, so the readout has little to memorize; near-GD accuracy at ~10% backward cost."}, {"id": "draft6_0_src_phase1_exp1_tap_all_layers", "label": "Tap ALL SCFF layers (S3 correction)", "file_type": "rationale", "source_file": "draft6.0\\src\\phase1\\exp1\\experiment-1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "SCFF separability degrades with depth, so the last-2 taps read the worst features; switching to all-layer taps (the SCFF paper's readout) recovered +0.17\u2192+0.21 on MNIST. S3's 'last n' is corrected to 'all layers'."}, {"id": "draft6_0_src_phase1_exp1_depth_degradation", "label": "SCFF features degrade with depth", "file_type": "concept", "source_file": "draft6.0\\src\\phase1\\exp1\\experiment-1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each SCFF layer re-optimizes goodness (density) and sheds class-relevant directions, so features degrade with depth (MNIST [0.82\u21920.52]); the value is in the early layers \u2014 the finding that drove Phase 2."}], "edges": [{"source": "draft6_0_src_phase1_exp1_experiment_1_doc", "target": "draft6_0_src_phase1_exp1_memorization_gap", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\src\\phase1\\exp1\\experiment-1.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_src_phase1_exp1_experiment_1_doc", "target": "draft6_0_src_phase1_exp1_tap_all_layers", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\src\\phase1\\exp1\\experiment-1.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_src_phase1_exp1_experiment_1_doc", "target": "draft6_0_src_phase1_exp1_depth_degradation", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\src\\phase1\\exp1\\experiment-1.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_src_phase1_exp1_depth_degradation", "target": "draft6_0_src_phase1_exp1_tap_all_layers", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\src\\phase1\\exp1\\experiment-1.md", "source_location": null, "weight": 1.0}, {"source": "draft6_0_src_phase1_exp1_experiment_1_doc", "target": "draft6_0_src_phase1_exp0_experiment_0_doc", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft6.0\\src\\phase1\\exp1\\experiment-1.md", "source_location": null, "weight": 1.0}], "hyperedges": []}