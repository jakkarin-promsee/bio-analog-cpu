{"nodes": [{"id": "draft_journey_draft4_1", "label": "Draft 4.1 Spec", "file_type": "document", "source_file": "draft-journey\\draft4.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Canonical attribution-era spec (v4.1); supersedes 4.0; patches multi-parent direction (Forward_Sign_SRAM), Range Sensitivity PGA, analog robustness (\u00a714), physical saturation."}, {"id": "draft_journey_draft4_1_forward_sign_sram", "label": "Forward_Sign_SRAM (multi-parent direction fix)", "file_type": "concept", "source_file": "draft-journey\\draft4.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Per-Scap 1-bit latch of sign(a.W) during the last forward pass; direction = Forward_Sign XOR feedback resolves per-Scap update direction even when parents disagree. Only carries new info under signed activations (degenerate under ReLU)."}, {"id": "draft_journey_draft4_1_physical_saturation", "label": "Physical saturation (implicit L2 regularization)", "file_type": "rationale", "source_file": "draft-journey\\draft4.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The weight cap's supply-rail ceiling (dV/dt -> 0 at the rail) self-limits winners for free - the primary defense against winner-take-all / Activity-vs-Relevance (H10), functionally equivalent to L2 with no loss term."}, {"id": "draft_journey_draft4_1_residual_bypass", "label": "Residual bypass (anti dead-weight collapse)", "file_type": "rationale", "source_file": "draft-journey\\draft4.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Direct L1->L4 wire summed with the computed path; routes signal around dead weights - the main intervention against dead-weight collapse, the worst failure mode of attribution-based learning. Carried into draft 6 in spirit (confirmed by boosting theory)."}, {"id": "draft_journey_draft4_1_momentum_floor_at_1", "label": "Momentum SRAM + floor-at-1", "file_type": "rationale", "source_file": "draft-journey\\draft4.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "16-bit per-Scap EMA of contribution (alpha=3/4 via right-shift); pinned at 1 when decaying so a zero-momentum Scap can't receive zero update forever; structurally an eligibility trace."}, {"id": "draft_journey_draft4_1_range_sensitivity_pga", "label": "Range Sensitivity (Programmable Gain Amplifier)", "file_type": "concept", "source_file": "draft-journey\\draft4.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A switchable-gain (coarse/fine) amplifier on measurement caps; fine mode during deep convergence discriminates weak currents that would clip at T_max; triggered globally by Brainstem or locally by an 80%-clipping Lobe counter."}, {"id": "draft_journey_draft4_1_analog_robustness_mechanisms", "label": "Analog Robustness Mechanisms (PVT defense)", "file_type": "rationale", "source_file": "draft-journey\\draft4.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Differential-pair op-amps, Dummy-Scap calibration, Current-Mirror loss share, Auto-Zeroing phases, Range Sensitivity - not optional; what makes the analog substrate physically realizable against process/voltage/thermal drift."}], "edges": [{"source": "draft_journey_draft4_1", "target": "draft_journey_draft5_1_full_scap", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "draft-journey\\draft4.1.md", "source_location": null, "weight": 1.0}, {"source": "draft_journey_draft4_1", "target": "draft_journey_draft5_1_full_ganglion", "relation": "references", "confidence": "EXTRACTED", "confidence_score"